# =============================================================
# Animal Lifecycle Platform — Configuração do Backend
# =============================================================
# Copie este arquivo para o servidor e preencha com os valores reais.
# NUNCA compartilhe este arquivo com valores reais preenchidos.
# =============================================================


# -------------------------------------------------------------
# Banco de Dados
# -------------------------------------------------------------

# URL de conexão com o PostgreSQL.
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
# Exemplo local:   postgresql://postgres:senha123@localhost:5432/animais
# Exemplo remoto:  postgresql://admin:xK9$mP2@192.168.1.10:5432/animais_prod
DATABASE_URL=postgresql://postgres:troque_essa_senha@localhost:5432/animal_lifecycle


# -------------------------------------------------------------
# Sincronização com o MindTrace
# -------------------------------------------------------------

# Chave secreta compartilhada entre o MindTrace e este backend.
# Deve ser uma string longa e aleatória — mesma valor configurado no MindTrace.
# Gerar sugestão: python -c "import secrets; print(secrets.token_hex(32))"
SYNC_SECRET=troque_por_uma_chave_aleatoria_longa_ex_a3f8b2c1d4e5f6a7b8c9d0e1f2a3b4c5

# Se True, permite sincronização de qualquer caminho de arquivo do MindTrace.
# Em produção, mantenha False e configure os caminhos permitidos.
# Valores aceitos: true / false
MINDTRACE_ALLOW_ANY_PATH=false

# Tolerância máxima (em segundos) entre o timestamp da requisição de sync
# e o horário do servidor. Protege contra ataques de replay.
# Valor recomendado: 30 (30 segundos)
SYNC_MAX_SKEW_SECONDS=30


# -------------------------------------------------------------
# Autenticação e Tokens JWT
# -------------------------------------------------------------

# Chave secreta para assinar tokens JWT.
# Deve ser longa e aleatória — nunca reutilize entre ambientes.
# Gerar sugestão: python -c "import secrets; print(secrets.token_hex(64))"
AUTH_SECRET=troque_por_outra_chave_aleatoria_longa_ex_d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0

# Tempo de vida do token JWT em segundos.
# 86400 = 24 horas | 3600 = 1 hora | 604800 = 7 dias
AUTH_TOKEN_TTL_SECONDS=86400

# Máximo de tentativas de login falhas antes de bloquear a conta.
AUTH_MAX_FAILED_ATTEMPTS=5

# Tempo de bloqueio da conta após exceder tentativas falhas (em minutos).
AUTH_LOCK_MINUTES=15


# -------------------------------------------------------------
# Controle de Acesso por IP (CIDR)
# -------------------------------------------------------------
# Use notação CIDR separada por vírgula.
# Exemplos:
#   Rede local completa:     192.168.1.0/24
#   IP único:                192.168.1.50/32
#   Qualquer IP (sem restrição): 0.0.0.0/0
#
# ATENÇÃO: Em produção, restrinja sempre aos IPs conhecidos do laboratório.

# IPs permitidos para uso geral da API (leitura de dados, sync, etc.)
AUTH_ALLOWED_CIDRS=192.168.1.0/24

# IPs permitidos para fazer login (obter token)
AUTH_LOGIN_ALLOWED_CIDRS=192.168.1.0/24

# IPs permitidos para acessar rotas administrativas
AUTH_ADMIN_ALLOWED_CIDRS=192.168.1.10/32,192.168.1.11/32


# -------------------------------------------------------------
# Controle de Acesso Administrativo por MAC Address
# -------------------------------------------------------------
# Lista de endereços MAC das máquinas autorizadas a acessar rotas de admin.
# Formato: XX:XX:XX:XX:XX:XX separados por vírgula (letras maiúsculas).
# Deixe vazio para desativar a restrição por MAC.
# Como descobrir o MAC: execute "ipconfig /all" no Windows ou "ip link" no Linux.
AUTH_ADMIN_ALLOWED_MACS=AA:BB:CC:DD:EE:FF,11:22:33:44:55:66


# -------------------------------------------------------------
# CORS — Origens Permitidas
# -------------------------------------------------------------
# URLs do frontend autorizadas a fazer requisições ao backend.
# Separe múltiplas origens por vírgula, sem espaços.
# Exemplos:
#   App mobile local (Expo):  http://localhost:8081
#   Produção:                 https://animais.seudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://192.168.1.0:8081
